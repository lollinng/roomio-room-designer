{
  "name": "roomio-rendering",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Agent G — Realistic Rendering. A drop-in R3F realism layer (PBR + IBL + ACESFilmic tone mapping + AO + emissive bulbs/bloom + area lights) that sits on top of Agent E's lighting, plus a standalone furnished-room harness to verify it in isolation.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "node scripts/verify.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "2.19.1",
    "postprocessing": "6.37.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "three-gpu-pathtracer": "0.0.23",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "puppeteer-core": "^23.11.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.9"
  }
}
